NODE_ENV=development
HOST=127.0.0.1
PORT=8080
LOG_LEVEL=info
CORS_ORIGIN=*

# Use HOST=0.0.0.0 when running in Docker/container and need external access.

# PostgreSQL
# Set to true to enable real DB connection
DB_ENABLED=false

# Optional full connection string. If set, it takes precedence.
# Example: postgres://hotel_user:hotel_password@127.0.0.1:5432/hotel_booking
DATABASE_URL=

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=hotel_booking
DB_USER=hotel_user
DB_PASSWORD=hotel_password

# SSL options for managed PostgreSQL
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# Pool tuning
DB_POOL_MIN=0
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=10000
DB_CONNECTION_TIMEOUT_MS=5000
